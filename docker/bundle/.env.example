# HAAP local evaluation bundle — example configuration.
#
# Copy this file to `.env` and fill in the values below. At minimum you must
# provide HAWCX_ORG_ID, HAWCX_IK_C, HAAP_AUDIENCE_HASH, and HAAP_SEALER_PASSPHRASE
# for the services to actually function. Without them, the containers will start
# but the CAA admin-auth process and the RSV will fail to initialise.

# ----------------------------------------------------------------------------
# Version pin
# ----------------------------------------------------------------------------

# HAAP version pin. Override if testing a specific release.
HAAP_VERSION=v0.1.0-alpha.1

# ----------------------------------------------------------------------------
# CAA (Customer Admin Agent) — required
# ----------------------------------------------------------------------------

# Organization identifier. Distinct per customer organization. Rejected if
# empty or whitespace-only.
HAWCX_ORG_ID=

# Admin identity key material. Either provide the key inline here, or set
# HAWCX_IK_C_FILE to a path mounted into the caa-admin-auth container and
# remove HAWCX_IK_C from the compose env.
# For evaluation: contact Hawcx to provision a tenant IK_c.
HAWCX_IK_C=

# Bootstrap one-time recovery credential (OTRC). Required for first-run
# enrollment against the Authorization Server. Provided by Hawcx alongside IK_c.
HAAP_BOOTSTRAP_OTRC=

# CAA principal identifier. Defaults to HAWCX_ORG_ID if left empty.
HAAP_CAA_PRINCIPAL_ID=

# K_admin_session as 64 hex chars (32 bytes). Optional; auto-generated on
# first startup if omitted, but pin it for reproducible evaluation sessions.
HAAP_CAA_K_ADMIN_SESSION_HEX=

# Admin Authenticator session TTL (seconds).
HAAP_ADMIN_AUTH_SESSION_TTL=3600

# ----------------------------------------------------------------------------
# CAA — AS endpoint
# ----------------------------------------------------------------------------

# Authorization Server endpoint. Defaults to Hawcx production AS.
# For staging evaluation, override to https://stage-api.hawcx.com.
HAAP_AS_URL=https://agent-auth.hawcx.com

# ----------------------------------------------------------------------------
# RSV (Resource Server Verifier) — required
# ----------------------------------------------------------------------------

# Audience hash (32-byte hex). Must match the aud_hash in HAAP tokens issued
# to your APIs. Provided by Hawcx as part of audience registration.
HAAP_AUDIENCE_HASH=

# Passphrase used by the file sealer to wrap K_RS at rest. CHANGE THIS to a
# strong random secret for any deployment beyond a throwaway evaluation.
HAAP_SEALER_PASSPHRASE=

# Replay LRU capacity (entries). Tune based on expected request volume.
HAAP_REPLAY_LRU_CAPACITY=10000

# ----------------------------------------------------------------------------
# Operational settings
# ----------------------------------------------------------------------------

# Production-mode gate. Set to "true" only when running with valid mTLS certs,
# pinned server certs, and other production hardening configured.
HAAP_PRODUCTION_MODE=false

# Port mappings (host-side). Adjust if you have conflicts.
CAA_GRPC_PORT=9443
RSV_PORT=8443

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info
